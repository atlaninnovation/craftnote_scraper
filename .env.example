# Craftnote API
# Copy this file to secrets.env and fill in your credentials
CRAFTNOTE_URL=https://europe-west1-craftnote-live.cloudfunctions.net
CRAFTNOTE_API_KEY=your-api-key-here
CRAFTNOTE_EMAIL=your-email@example.com
CRAFTNOTE_PASSWORD=your-password-here

# MinIO Storage (required for --upload-to-minio)
# Production endpoint (WindeeProd)
MINIO_ENDPOINT=10.25.10.104:9000
# Development endpoints (alternative examples)
# MINIO_ENDPOINT=minio.local:9000
# MINIO_ENDPOINT=10.10.10.55:9000
MINIO_ACCESS_KEY=windee
MINIO_SECRET_KEY=windee-minio-secret-key-32chars!
MINIO_USE_SSL=false
MINIO_BUCKET=service-reports
